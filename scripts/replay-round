#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
DIST_DIR="$ROOT_DIR/dist/tournament-cli"
JAR_FILE="$DIST_DIR/dicewars-tournament-cli-all.jar"
HASH_FILE="$DIST_DIR/source.hash"

SOURCE_INPUTS=(
  "shared/src/commonMain/kotlin"
  "shared/src/jvmMain/kotlin"
  "tournamentCli/src/main/kotlin"
  "build.gradle.kts"
  "settings.gradle.kts"
  "shared/build.gradle.kts"
  "tournamentCli/build.gradle.kts"
  "gradle/libs.versions.toml"
)

compute_source_hash() {
  local tmp
  tmp="$(mktemp)"
  (
    cd "$ROOT_DIR"
    for path in "${SOURCE_INPUTS[@]}"; do
      if [[ -d "$path" ]]; then
        while IFS= read -r file; do
          local file_hash
          file_hash="$(shasum -a 256 "$file" | awk '{print $1}')"
          printf '%s  %s\n' "$file_hash" "$file" >> "$tmp"
        done < <(find "$path" -type f | sort)
      elif [[ -f "$path" ]]; then
        local file_hash
        file_hash="$(shasum -a 256 "$path" | awk '{print $1}')"
        printf '%s  %s\n' "$file_hash" "$path" >> "$tmp"
      fi
    done
  )
  local final_hash
  final_hash="$(shasum -a 256 "$tmp" | awk '{print $1}')"
  rm -f "$tmp"
  printf '%s' "$final_hash"
}

mkdir -p "$DIST_DIR"
CURRENT_HASH="$(compute_source_hash)"
RECORDED_HASH=""
if [[ -f "$HASH_FILE" ]]; then
  RECORDED_HASH="$(tr -d '[:space:]' < "$HASH_FILE")"
fi

if [[ -f "$JAR_FILE" && "$CURRENT_HASH" == "$RECORDED_HASH" ]]; then
  echo "Tournament CLI unchanged; using existing build." >&2
else
  echo "Tournament CLI source changed or artifact missing; rebuilding..." >&2
  (cd "$ROOT_DIR" && ./gradlew --no-configuration-cache :tournamentCli:generateTournamentDist --console=plain)
  printf '%s' "$CURRENT_HASH" > "$HASH_FILE"
fi

exec java -jar "$JAR_FILE" replay-round "$@"
