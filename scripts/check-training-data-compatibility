#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
OUT_FILE="$(mktemp -t dicewars-imitation.XXXXXX.jsonl.gz)"
cleanup() {
  rm -f "$OUT_FILE"
}
trap cleanup EXIT

(
  cd "$ROOT_DIR"
  ./scripts/training-cli generate-imitation-data \
    --rounds 1 \
    --seed 20260520 \
    --bots bully,turtle \
    --max-actions 500 \
    --out "$OUT_FILE" >/dev/null

  PYTHONPATH=training python3 - <<'PY' "$OUT_FILE"
import sys
from dicewars_nn.dataset import load_jsonl_gz

path = sys.argv[1]
records = list(load_jsonl_gz(path))
if not records:
    raise SystemExit("no records generated")
policy_records = [record for record in records if record.policy_weight == 1.0]
if not policy_records:
    raise SystemExit("no policy records generated")
print(f"Training data compatibility OK: {len(records)} records, {len(policy_records)} policy records")
PY
)
