#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

VENV_ACTIVATE="$ROOT_DIR/training/.venv/bin/activate"
if [[ ! -f "$VENV_ACTIVATE" ]]; then
  echo "Missing Python venv: $VENV_ACTIVATE" >&2
  exit 1
fi

DATA_PATH="$ROOT_DIR/training/data/imitation-v1.jsonl.gz"
CACHE_PATH="$ROOT_DIR/training/cache/imitation-v1-terminator2.pt"

GENERATION=""
ROUNDS=10000
SEED=""
DRY_RUN=0
PROMOTE_ONLY_IF_SCORE_GAIN=0

usage() {
  cat <<EOF
Usage: $(basename "$0") --generation <id> [options]

Options:
  --generation <id>   Generation label (e.g. g001)
  --rounds <count>    Tournament rounds (default: 10000)
  --seed <int>        Tournament seed (optional)
  --dry-run           Print commands only
  --promote-only-if-score-gain <pts>
                      Promote only if best score >= previous_score + pts (default: 0)
  --help              Show this help

Environment:
  EVOLVE_PARENT_CHECKPOINT  Optional parent checkpoint (.pt) for fine-tuning
                            default: training/checkpoints/imitation-terminator2/latest.pt
  EVOLVE_CHAMPION_MODEL     Optional champion ONNX model path
                            default: models/neuralbot/current/model.onnx
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --generation)
      GENERATION="$2"; shift 2 ;;
    --rounds)
      ROUNDS="$2"; shift 2 ;;
    --seed)
      SEED="$2"; shift 2 ;;
    --dry-run)
      DRY_RUN=1; shift ;;
    --promote-only-if-score-gain)
      PROMOTE_ONLY_IF_SCORE_GAIN="$2"; shift 2 ;;
    --help)
      usage; exit 0 ;;
    *)
      echo "Unknown arg: $1" >&2
      usage >&2
      exit 1 ;;
  esac
done

if [[ -z "$GENERATION" ]]; then
  echo "--generation is required" >&2
  usage >&2
  exit 1
fi

if ! [[ "$PROMOTE_ONLY_IF_SCORE_GAIN" =~ ^-?[0-9]+$ ]]; then
  echo "--promote-only-if-score-gain must be an integer" >&2
  exit 1
fi
if [[ "$PROMOTE_ONLY_IF_SCORE_GAIN" -lt 0 ]]; then
  echo "--promote-only-if-score-gain must be >= 0" >&2
  exit 1
fi

PARENT_CHECKPOINT="${EVOLVE_PARENT_CHECKPOINT:-$ROOT_DIR/training/checkpoints/imitation-terminator2/latest.pt}"
if [[ ! -f "$PARENT_CHECKPOINT" ]]; then
  echo "Parent checkpoint not found: $PARENT_CHECKPOINT" >&2
  echo "Set EVOLVE_PARENT_CHECKPOINT to a valid checkpoint path." >&2
  exit 1
fi

CHAMPION_MODEL="${EVOLVE_CHAMPION_MODEL:-$ROOT_DIR/models/neuralbot/current/model.onnx}"
if [[ ! -f "$CHAMPION_MODEL" && -f "$ROOT_DIR/models/neural-v1-terminator2.onnx" ]]; then
  CHAMPION_MODEL="$ROOT_DIR/models/neural-v1-terminator2.onnx"
fi
if [[ ! -f "$CHAMPION_MODEL" ]]; then
  echo "Champion model not found: $CHAMPION_MODEL" >&2
  echo "Set EVOLVE_CHAMPION_MODEL to a valid ONNX model path." >&2
  exit 1
fi

OUT_DIR="$ROOT_DIR/models/neuralbot/$GENERATION"
REPORT_DIR="$ROOT_DIR/training/reports/evolution/$GENERATION"
mkdir -p "$OUT_DIR" "$REPORT_DIR"

# Mutant hyperparams (conservative -> aggressive)
variant_lr() {
  case "$1" in
    a) echo 0.0005 ;;
    b) echo 0.0008 ;;
    c) echo 0.0010 ;;
    d) echo 0.0012 ;;
    e) echo 0.0015 ;;
    f) echo 0.0020 ;;
    *) echo "unknown variant: $1" >&2; exit 1 ;;
  esac
}

variant_epochs() {
  case "$1" in
    a) echo 12 ;;
    b) echo 16 ;;
    c) echo 20 ;;
    d) echo 24 ;;
    e) echo 28 ;;
    f) echo 32 ;;
    *) echo "unknown variant: $1" >&2; exit 1 ;;
  esac
}

variant_batch() {
  case "$1" in
    a|b|c) echo 1024 ;;
    d|e|f) echo 2048 ;;
    *) echo "unknown variant: $1" >&2; exit 1 ;;
  esac
}

run_cmd() {
  if [[ "$DRY_RUN" -eq 1 ]]; then
    echo "+ $*"
  else
    eval "$@"
  fi
}

source "$VENV_ACTIVATE"

# Champion occupies neural-a; train/export mutant variants neural-b..neural-f
echo "=== Champion neural-a: $CHAMPION_MODEL ==="
run_cmd "cp '$CHAMPION_MODEL' '$OUT_DIR/neural-a.onnx'"

for key in b c d e f; do
  variant="neural-$key"
  lr="$(variant_lr "$key")"
  epochs="$(variant_epochs "$key")"
  batch="$(variant_batch "$key")"
  ckpt_dir="$ROOT_DIR/training/checkpoints/evolution/$GENERATION/$variant"
  model_out="$OUT_DIR/$variant.onnx"
  echo "=== Training $variant (lr=$lr, epochs=$epochs, batch=$batch) ==="
  cmd="cd '$ROOT_DIR/training' && PYTHONPATH=. python3 -m dicewars_nn.train_imitation \
    '$DATA_PATH' \
    --filter-bot terminator2 \
    --tensor-cache '$CACHE_PATH' \
    --resume-checkpoint '$PARENT_CHECKPOINT' \
    --epochs $epochs \
    --batch-size $batch \
    --lr $lr \
    --checkpoint-dir '$ckpt_dir' \
    --export-onnx '$model_out'"
  run_cmd "$cmd"
done

TOURNAMENT_REPORT="$REPORT_DIR/tournament.txt"
SEED_ARGS=""
if [[ -n "$SEED" ]]; then
  SEED_ARGS="--seed $SEED"
fi

JAVA_OPTS="-Ddicewars.neural.model.a=$OUT_DIR/neural-a.onnx \
-Ddicewars.neural.model.b=$OUT_DIR/neural-b.onnx \
-Ddicewars.neural.model.c=$OUT_DIR/neural-c.onnx \
-Ddicewars.neural.model.d=$OUT_DIR/neural-d.onnx \
-Ddicewars.neural.model.e=$OUT_DIR/neural-e.onnx \
-Ddicewars.neural.model.f=$OUT_DIR/neural-f.onnx"

echo "=== Running tournament ($ROUNDS rounds) ==="
cmd="cd '$ROOT_DIR' && DICEWARS_TOURNAMENT_JAVA_OPTS=\"$JAVA_OPTS\" ./scripts/run-tournament \
  --bots neural-a,neural-b,neural-c,neural-d,neural-e,neural-f,terminator2 \
  --rounds $ROUNDS $SEED_ARGS | tee '$TOURNAMENT_REPORT'"
run_cmd "$cmd"

if [[ "$DRY_RUN" -eq 1 ]]; then
  echo "Dry-run complete."
  exit 0
fi

# Parse champion score (Neural A) and best mutant score (Neural B..F)
SELECTION_LINE=$(python3 - "$TOURNAMENT_REPORT" <<'PY'
import re, sys
text = open(sys.argv[1], 'r', encoding='utf-8').read().splitlines()
scores = {}
for line in text:
    m = re.match(r'^\s*\d+\.\s+Neural\s+([A-F])\s+([0-9,]+)\s+pts', line)
    if not m:
        continue
    key = m.group(1).lower()
    score = int(m.group(2).replace(',', ''))
    scores[key] = score
if 'a' not in scores:
    raise SystemExit('Missing Neural A (champion) score in tournament report')
mutants = {k: v for k, v in scores.items() if k in 'bcdef'}
if not mutants:
    raise SystemExit('No mutant neural scores found in tournament report')
best_key, best_score = max(mutants.items(), key=lambda kv: kv[1])
print(f"{scores['a']}|{best_key}|{best_score}")
PY
)

CHAMPION_SCORE="${SELECTION_LINE%%|*}"
REST="${SELECTION_LINE#*|}"
BEST_KEY="${REST%%|*}"
BEST_SCORE="${REST##*|}"
BEST_VARIANT="neural-$BEST_KEY"
BEST_MODEL="$OUT_DIR/$BEST_VARIANT.onnx"
BEST_CKPT_DIR="$ROOT_DIR/training/checkpoints/evolution/$GENERATION/$BEST_VARIANT"
BEST_CKPT="$BEST_CKPT_DIR/latest.pt"

REQUIRED_SCORE=$((CHAMPION_SCORE + PROMOTE_ONLY_IF_SCORE_GAIN))
PROMOTED=0
PROMOTION_REASON=""
if [[ "$BEST_SCORE" -ge "$REQUIRED_SCORE" ]]; then
  PROMOTED=1
  PROMOTION_REASON="best_mutant_score >= champion_score + gain"
else
  PROMOTION_REASON="best_mutant_score < champion_score + gain"
fi

CURRENT_DIR="$ROOT_DIR/models/neuralbot/current"
mkdir -p "$CURRENT_DIR"
if [[ "$PROMOTED" -eq 1 ]]; then
  cp "$BEST_MODEL" "$CURRENT_DIR/model.onnx"
  if [[ -f "$BEST_CKPT" ]]; then
    cp "$BEST_CKPT" "$CURRENT_DIR/latest.pt"
  fi
  printf '%s\n' "$GENERATION/$BEST_VARIANT" > "$ROOT_DIR/models/neuralbot/current.txt"
fi

cat > "$REPORT_DIR/selection.txt" <<EOF
generation: $GENERATION
rounds: $ROUNDS
seed: ${SEED:-none}
champion_variant: neural-a
champion_score: $CHAMPION_SCORE
best_mutant_variant: $BEST_VARIANT
best_mutant_score: $BEST_SCORE
promote_only_if_score_gain: $PROMOTE_ONLY_IF_SCORE_GAIN
required_score_for_promotion: $REQUIRED_SCORE
promoted: $PROMOTED
promotion_reason: $PROMOTION_REASON
source_model: $BEST_MODEL
EOF

echo "=== Selection complete ==="
echo "Champion score: $CHAMPION_SCORE"
echo "Best mutant: $BEST_VARIANT ($BEST_SCORE pts)"
if [[ "$PROMOTED" -eq 1 ]]; then
  echo "Promoted to: $CURRENT_DIR/model.onnx"
else
  echo "Champion retained (no promotion)."
fi
